# Copy to deploy.env and fill in (never commit deploy.env)
# Used by: ./scripts/deploy-cloud.sh

# App Runner service URL (no trailing slash)
APP_RUNNER_URL=https://xxxxxxxx.us-east-1.awsapprunner.com

# AWS Amplify app (Console → App settings → General)
AMPLIFY_APP_ID=dxxxxxxxx

# Branch to configure
AMPLIFY_BRANCH=main

# App Runner — from Console after first create, or leave empty to only update Amplify
APP_RUNNER_SERVICE_ARN=

# Backend secrets (App Runner environment variables)
DATABASE_URL=postgresql://user:pass@host.neon.tech/db?sslmode=require
TMDB_API_KEY=your_tmdb_v3_key

# Optional extra CORS origins (comma-separated). Amplify URLs are allowed automatically.
CORS_ORIGINS=

# Set false after first successful deploy
SEED_ON_STARTUP=true

# AWS region
AWS_REGION=us-east-1
