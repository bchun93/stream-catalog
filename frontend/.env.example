# Local dev: leave empty — Vite proxies /api to localhost:8000
# VITE_API_URL=

# Production (set in Amplify → Environment variables)
# VITE_API_URL=https://stream-catalog.onrender.com

# Optional — required when INGEST_OPERATOR_TOKEN is set on the API
# VITE_INGEST_OPERATOR_TOKEN=your_token_here

# Required in production when ADMIN_API_KEY is set on the API (use the same value)
# VITE_ADMIN_API_KEY=your_admin_key_here
