# Local development (copy to .env)
DATABASE_URL=sqlite:///../data/catalog.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SEED_ON_STARTUP=true

# Free API key: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Production (Render / cloud) — use a managed Postgres URL instead
# DATABASE_URL=postgresql://user:pass@host.neon.tech/neondb?sslmode=require
# TMDB_API_KEY=your_tmdb_v3_key
# INGEST_S3_BUCKET=stream-catalog-ingest
# INGEST_S3_PREFIX=deliveries
# ASPERA_DROP_PREFIX=inbound
# INGEST_OPERATOR_TOKEN=change-me
# SEED_ON_STARTUP=true
# CORS_ORIGINS=https://catalog.yourdomain.com
# CORS_ORIGIN_REGEX=   # leave default to allow *.amplifyapp.com
