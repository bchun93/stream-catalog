# Local development (copy to .env)
DATABASE_URL=sqlite:///../data/catalog.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SEED_ON_STARTUP=true

# Free API key: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Production (Render / cloud) — use a managed Postgres URL instead
# DATABASE_URL=postgresql://user:pass@host.neon.tech/neondb?sslmode=require
# TMDB_API_KEY=your_tmdb_v3_key
# INGEST_S3_BUCKET=stream-catalog-ingest
# INGEST_S3_PREFIX=deliveries
# ASPERA_DROP_PREFIX=inbound
# INGEST_OPERATOR_TOKEN=change-me
# ADMIN_API_KEY=change-me-long-random-string
# AWS_PROFILE=stream-catalog-dev
# AWS_REGION=us-east-1
# Or for Render / CI only (avoid on laptop if using SSO):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# SEED_ON_STARTUP=true
# CORS_ORIGINS=https://catalog.yourdomain.com
# CORS_ORIGIN_REGEX=   # leave default to allow *.amplifyapp.com

# --- Amazon Rekognition Video (see docs/REKOGNITION_AWS_SETUP.md) ---
# Analyze the H.264 MP4 proxy in place from its S3 bucket; status comes via SNS->SQS only.
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=        # app credentials (IAM user from setup section 6)
# AWS_SECRET_ACCESS_KEY=
# S3_ANALYSIS_BUCKET=relay-rekognition-analysis
# REKOGNITION_ROLE_ARN=arn:aws:iam::<acct>:role/RelayRekognitionServiceRole
# REKOGNITION_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:<acct>:AmazonRekognition-relay-completion
# REKOGNITION_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<acct>/relay-rekognition-completion
# DDB_JOBS_TABLE=relay_rekognition_jobs
# DDB_DETECTIONS_TABLE=relay_rekognition_detections
# REKOGNITION_CONSUMER_SECRET=   # long random string; protects POST /rekognition/consume
